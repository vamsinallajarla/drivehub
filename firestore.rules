// firestore.rules
// Copy this into: Firebase console → Firestore Database → Rules → publish.
// This file is just documentation/reference for this repo — Firestore rules
// live on Firebase's servers, not in your deployed site, so this being
// public on GitHub reveals nothing sensitive.

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{email} {
      // Anyone can look up a single user doc by its exact email (needed for
      // login / forgot-password), but nobody can list/dump the collection.
      allow get: if true;
      allow list: if false;

      // Anyone can create an account, as long as the doc only contains the
      // expected fields and its email field matches its own document ID.
      allow create: if request.resource.data.keys().hasOnly(
                        ['email', 'salt', 'passwordHash', 'securityQuestion', 'securityAnswerHash', 'createdAt']
                      )
                      && request.resource.data.email == email;

      // Updates may only ever touch salt/passwordHash (used by both
      // "change password" and "forgot password" resets). Note: these rules
      // can't verify *why* the update is happening (i.e. that the caller
      // actually knew the old password or answered the security question
      // correctly) — that check only happens in the browser's JS. See the
      // caveat in the app's chat history / README for details.
      allow update: if request.resource.data.diff(resource.data).affectedKeys().hasOnly(['salt', 'passwordHash']);

      allow delete: if false;
    }

    // Everything else stays fully locked down.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
